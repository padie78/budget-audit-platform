{
  "name": "budget-audit-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/budget-audit-web/src",
  "prefix": "app",
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/budget-audit-web",
        "index": "apps/budget-audit-web/src/index.html",
        "main": "apps/budget-audit-web/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/budget-audit-web/tsconfig.app.json",
        "assets": ["apps/budget-audit-web/src/favicon.ico"],
        "styles": ["apps/budget-audit-web/src/styles.scss"],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/budget-audit-web/src/environments/environment.ts",
              "with": "apps/budget-audit-web/src/environments/environment.prod.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "budget-audit-web:build:production"
        },
        "development": {
          "buildTarget": "budget-audit-web:build:development"
        }
      },
      "defaultConfiguration": "development"
    }
  },
  "tags": ["scope:web", "type:app"]
}
